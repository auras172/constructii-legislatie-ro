{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/constructii-legislatie-ro/metadata/schema.json",
  "title": "Romanian construction legislation metadata",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "title",
    "type",
    "domain",
    "status",
    "source_url",
    "last_checked",
    "tags"
  ],
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1
    },
    "short_title": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "lege",
        "ordonanta",
        "hotarare",
        "ordin",
        "normativ",
        "ghid",
        "procedura"
      ]
    },
    "number": {
      "type": [
        "string",
        "integer"
      ]
    },
    "year": {
      "type": [
        "string",
        "integer"
      ]
    },
    "domain": {
      "type": "string",
      "enum": [
        "autorizatii",
        "urbanism",
        "executie",
        "receptie",
        "calitate",
        "isc",
        "anre",
        "iscir",
        "incendiu",
        "nzeb",
        "fiscal",
        "munca",
        "mediu"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "repealed",
        "partially_repealed",
        "unknown"
      ]
    },
    "source_url": {
      "type": "string",
      "minLength": 1
    },
    "official_source": {
      "type": "string"
    },
    "last_checked": {
      "type": "string",
      "format": "date"
    },
    "version": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    }
  }
}
